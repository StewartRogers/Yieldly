# ── Database ─────────────────────────────────────────────────────────────────
# Local development needs NEITHER variable: the app falls back to a local
# `file:yieldly.db` libSQL database.
#
# For hosted/Vercel deployment, point at a Turso database:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWT auth tokens.
# REQUIRED in production: server.js and the Vercel function refuse to start
# without it. In local dev an ephemeral secret is generated (tokens reset on
# restart). Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Set to "1" if behind a reverse proxy terminating HTTPS (trusts the proxy and,
# in production, sets the Secure flag on the auth cookie). On Vercel this is
# handled by the serverless entrypoint (api/index.js) automatically.
TRUST_PROXY=

# Bearer token required on GET /api/cron/snapshot-values (the daily portfolio
# value snapshot triggered by Vercel Cron — see vercel.json). Must match the
# CRON_SECRET env var set on the Vercel project; Vercel then sends it
# automatically as `Authorization: Bearer <value>` on cron requests. Leaving
# this unset disables the route (always 401). Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Misc ─────────────────────────────────────────────────────────────────────
# Optional: AlphaVantage API key (reserved for future market-data integration)
ALPHA_KEY=

# Set to "1" to log per-row detail during CSV import (off by default).
DEBUG_IMPORT=
